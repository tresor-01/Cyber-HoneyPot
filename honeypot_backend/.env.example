# ──────────────────────────────────────────────────────────────────────────────
# Cyber-HoneyPot — Backend Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and adjust the values for your environment.
#
#   cp .env.example .env          (Linux / macOS)
#   Copy-Item .env.example .env   (Windows PowerShell)
#
# .env itself is gitignored and will never be committed to the repository.
# ──────────────────────────────────────────────────────────────────────────────

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── CORS — comma-separated list of your frontend origins ─────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Database — path to the SQLite file created automatically on first run ─────
DB_PATH=honeypot.db

# ── Unprivileged port mode ────────────────────────────────────────────────────
# Set to true  → uses ports 2222, 8080, 2121, 2323, 3306, 2525  (no root needed)
# Set to false → uses ports   22,   80,   21,   23, 3306,   25  (requires admin/sudo)
USE_ALT_PORTS=false

# ── Individual port overrides (optional — remove # to activate) ───────────────
# SSH_PORT=22
# HTTP_PORT=80
# FTP_PORT=21
# TELNET_PORT=23
# MYSQL_PORT=3306
# SMTP_PORT=25
# RDP_PORT=3389
# VNC_PORT=5900
# REDIS_PORT=6379
# PGSQL_PORT=5432

# ── Threat detection tuning ───────────────────────────────────────────────────
BRUTE_FORCE_THRESHOLD=5     # failed logins from one IP before a brute-force alert
PORT_SCAN_THRESHOLD=3       # services hit by one IP before a port-scan alert
BRUTE_WINDOW_SECONDS=60     # sliding time window (seconds) for the counts above
